{
    "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
    "rules": {
        "selector-class-pattern": null,
        "at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": ["source", "theme"]
            }
        ],
        "import-notation": "string"
    },
    "ignoreFiles": [
        "node_modules/**/*",
        "vendor/**/*",
        "storage/**/*",
        "bootstrap/cache/**/*",
        "public/build/**/*"
    ]
}
