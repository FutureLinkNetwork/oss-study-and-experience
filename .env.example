
# アプリケーション設定
# APP_KEY は php artisan key:generate で生成（必須）
# 本番環境では APP_ENV=production, APP_DEBUG=false を設定
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# アプリケーションのURL（必須） / Application URL (required)
APP_URL=http://localhost

# ロケール設定
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ログ設定
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB設定（必須）
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=db_name
DB_USERNAME=username
DB_PASSWORD=password

# セッション設定
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ブロードキャスト設定
BROADCAST_CONNECTION=log
# ファイルシステム設定
FILESYSTEM_DISK=local
# キュー設定
QUEUE_CONNECTION=database
# キャッシュ設定
CACHE_STORE=database
# CACHE_PREFIX=
MEMCACHED_HOST=127.0.0.1

# Redis設定
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# メール設定
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3設定（ファイル保存に使用。ローカルでは ACCESS_KEY / SECRET_KEY も必要）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# 郵便番号・デジタルアドレスAPI設定（郵便番号検索機能を使う場合に必須）
JP_POST_API_BASE_URL=
JP_POST_API_SECRET=
JP_POST_API_ID=

# Google reCaptcha設定（本番環境では必須。local/testing では無効）
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Basic認証設定
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
