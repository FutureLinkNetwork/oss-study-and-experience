{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint . --ext .js,.ts,.jsx,.tsx,.html,.blade.php",
        "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx,.html,.blade.php --fix",
        "lint:css": "stylelint \"**/*.css\"",
        "lint:css:fix": "stylelint \"**/*.css\" --fix",
        "format": "prettier --write \"**/*.{js,ts,jsx,tsx,html,css,scss,json,md,blade.php}\"",
        "format:check": "prettier --check \"**/*.{js,ts,jsx,tsx,html,css,scss,json,md,blade.php}\"",
        "lint:all": "npm run lint && npm run lint:css",
        "lint:all:fix": "npm run lint:fix && npm run lint:css:fix"
    },
    "devDependencies": {
        "@html-eslint/eslint-plugin": "^0.19.0",
        "@html-eslint/parser": "^0.19.0",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "laravel-vite-plugin": "^2.0.0",
        "prettier": "^3.3.0",
        "stylelint": "^16.0.0",
        "stylelint-config-standard": "^36.0.0",
        "stylelint-config-tailwindcss": "^0.0.7",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "chart.js": "^4.5.1",
        "jquery": "^3.7.1",
        "leaflet": "^1.9.4",
        "select2": "^4.0.13"
    }
}
